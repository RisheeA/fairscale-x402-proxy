# FairScale x402 Proxy Configuration
# Copy this file to .env and edit as needed

# Your FairScale API key (default is already set in code)
# FAIRSCALE_API_KEY=zpka_your_key_here

# Your Solana wallet address to receive USDC payments (default is already set)
# TREASURY_WALLET=YourSolanaWalletAddress

# Solana RPC endpoint (optional - defaults to public mainnet)
# For production, use a dedicated RPC like Helius or QuickNode
# SOLANA_RPC=https://api.mainnet-beta.solana.com

# Server port (optional - defaults to 3402)
# PORT=3402
